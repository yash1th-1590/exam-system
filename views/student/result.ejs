<!DOCTYPE html>
<html>
<head>
<title>Test Result</title>
<link rel="stylesheet" href="/style.css">
<style>
  .comment-box { background: #e3f2fd; padding: 15px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #2196f3; }
  .comment-title { font-weight: bold; color: #1976d2; margin-bottom: 8px; }
  .answer-review { background: #f5f5f5; padding: 15px; margin: 15px 0; border-radius: 8px; }
  .correct { color: #4caf50; font-weight: bold; }
  .incorrect { color: #f44336; font-weight: bold; }
  .correct-answer { background: #e8f5e9; padding: 8px 12px; border-radius: 6px; margin-top: 8px; font-size: 14px; border-left: 3px solid #4caf50; }
  .correct-answer strong { color: #2e7d32; }
  .info-row { display: flex; gap: 20px; margin: 10px 0; padding: 10px; background: #f8f9fa; border-radius: 8px; flex-wrap: wrap; }
  .badge-auto { background: #4caf50; color: white; padding: 3px 10px; border-radius: 20px; font-size: 12px; display: inline-block; }
  .badge-manual { background: #ff9800; color: white; padding: 3px 10px; border-radius: 20px; font-size: 12px; display: inline-block; }
</style>
</head>
<body>
<nav><span>🎓 <%= user.name %></span><a href="/student/dashboard">← Dashboard</a><a href="/logout">Logout</a></nav>
<div class="container">
  <h2>Result: <%= result.testTitle %></h2>
  
  <div class="info-row">
    <div><strong>Section:</strong> <%= result.studentSection || 'Not Assigned' %></div>
    <div><strong>Enrollment:</strong> <%= result.studentEnrollment || user.enrollmentNo || 'N/A' %></div>
    <div><strong>Submitted:</strong> <%= result.submittedAt %></div>
    <div>
      <% if(result.correctionMode === 'auto') { %>
        <span class="badge-auto">🤖 Auto-graded Test</span>
      <% } else { %>
        <span class="badge-manual">📝 Manual Evaluation Test</span>
      <% } %>
    </div>
  </div>
  
  <div class="result-box">
    <p class="big-score"><%= result.score !== null ? result.score : 'Pending' %> / <%= result.totalMarks %></p>
    <% if(result.percent !== null) { %>
      <p><%= result.percent %>%</p>
      <p class="<%= result.percent >= 50 ? 'pass' : 'fail' %> big">
        <%= result.percent >= 50 ? '🎉 PASS' : '😞 FAIL' %>
      </p>
    <% } else { %>
      <p class="big">⏳ Awaiting Evaluation</p>
    <% } %>
    <% if(result.evaluatedAt) { %>
      <p>Evaluated: <%= result.evaluatedAt %></p>
    <% } %>
  </div>
  
  <% if(result.teacherComment) { %>
    <div class="comment-box">
      <div class="comment-title">📝 Teacher's Comment:</div>
      <p><%= result.teacherComment %></p>
    </div>
  <% } %>
  
  <h3>Answer Review</h3>
  <% test.questions.forEach((q, idx) => {
    const answer = result.answers.find(a => a.qId === q.id);
    const isCorrect = answer && answer.awarded === q.marks;
  %>
    <div class="answer-review">
      <p><strong>Q<%= idx+1 %>.</strong> <%= q.question %> <span style="color:#666;">[<%= q.marks %> marks]</span></p>
      <p><strong>Your Answer:</strong> 
        <% if(q.type === 'multiple') { %>
          <%= (answer && answer.given && answer.given.length) ? answer.given.join(', ') : 'No answer' %>
        <% } else { %>
          <%= (answer && answer.given) || 'No answer' %>
        <% } %>
      </p>
      <p><strong>Marks Awarded:</strong> 
        <span class="<%= isCorrect ? 'correct' : (answer && answer.awarded > 0 ? '' : 'incorrect') %>">
          <%= (answer && answer.awarded !== null) ? answer.awarded : 'Pending' %> / <%= q.marks %>
        </span>
      </p>
      
      <!-- Show correct answer ONLY for auto-graded tests AND test is graded/evaluated -->
      <% if(result.correctionMode === 'auto' && result.status !== 'pending_evaluation') { %>
        <div class="correct-answer">
          <strong>✓ Correct Answer:</strong><br>
          <% if(q.type === 'multiple') { %>
            <%= Array.isArray(q.answer) ? q.answer.join(', ') : q.answer %>
          <% } else if(q.type === 'fillblank') { %>
            "<%= q.answer %>"
          <% } else if(q.type === 'single') { %>
            <%= q.answer %>
          <% } else { %>
            <%= q.answer || '(Sample answer provided by teacher)' %>
          <% } %>
        </div>
      <% } %>
      
      <!-- For manual evaluation, show correct answer only AFTER evaluated -->
      <% if(result.correctionMode === 'manual' && result.status === 'evaluated') { %>
        <div class="correct-answer" style="background: #fff3e0; border-left-color: #ff9800;">
          <strong>📝 Expected Answer (for reference):</strong><br>
          <% if(q.type === 'multiple') { %>
            <%= Array.isArray(q.answer) ? q.answer.join(', ') : q.answer %>
          <% } else if(q.type === 'fillblank') { %>
            "<%= q.answer %>"
          <% } else if(q.type === 'single') { %>
            <%= q.answer %>
          <% } else { %>
            <%= q.answer || '(Sample answer provided by teacher)' %>
          <% } %>
        </div>
      <% } %>
    </div>
  <% }) %>
  
  <a href="/student/dashboard" class="btn">Back to Dashboard</a>
</div>
</body>
</html>