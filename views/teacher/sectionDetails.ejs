<!DOCTYPE html>
<html>
<head>
<title><%= section.name %> - Section Details</title>
<link rel="stylesheet" href="/style.css">
<style>
  .student-list { margin-top: 20px; }
  .student-item { display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #eee; }
  .student-info { flex: 1; }
  .student-name { font-weight: bold; }
  .student-details { font-size: 12px; color: #666; }
  .remove-btn { background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer; }
  .add-student-form { background: #f8f9fa; padding: 20px; border-radius: 8px; margin: 20px 0; }
  .test-list { margin-top: 20px; }
  .test-item { background: #f8f9fa; padding: 10px; margin: 10px 0; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; }
  .section-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 12px; margin-bottom: 20px; }
  .danger-btn { background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer; margin-left: 10px; }
</style>
</head>
<body>
<nav><span>👩‍🏫 <%= user.name %></span><a href="/teacher/dashboard">← Dashboard</a><a href="/logout">Logout</a></nav>
<div class="container">
  <div class="section-header">
    <h2><%= section.name %></h2>
    <p>🏢 Department: <%= section.department %></p>
    <p><%= section.description %></p>
    <p>📅 Created: <%= section.createdAt %></p>
    <form method="POST" action="/teacher/section/<%= section.id %>/delete" style="display: inline;" onsubmit="return confirm('Delete this section? All students will be unassigned.')">
      <button type="submit" class="danger-btn">Delete Section</button>
    </form>
  </div>

  <div class="add-student-form">
    <h3>Add Student to Section</h3>
    <form method="POST" action="/teacher/section/<%= section.id %>/add-student">
      <select name="studentId" required style="width: 70%; padding: 8px; margin-right: 10px;">
        <option value="">Select a student</option>
        <% allStudents.forEach(student => { 
          if (!students.find(s => s.id === student.id)) { %>
            <option value="<%= student.id %>"><%= student.name %> (<%= student.username %>) - <%= student.enrollmentNo || 'No enrollment' %></option>
        <% } }); %>
      </select>
      <button type="submit" class="btn">Add Student</button>
    </form>
  </div>

  <h3>👥 Students in this Section (<%= students.length %>)</h3>
  <div class="student-list">
    <% if(students.length === 0){ %>
      <p>No students added yet.</p>
    <% } else { %>
      <% students.forEach(student => { %>
        <div class="student-item">
          <div class="student-info">
            <div class="student-name"><%= student.name %></div>
            <div class="student-details">
              Username: <%= student.username %> | 
              Enrollment: <%= student.enrollmentNo || 'N/A' %> |
              Joined: <%= student.createdAt || 'Recently' %>
            </div>
          </div>
          <form method="POST" action="/teacher/section/<%= section.id %>/remove-student/<%= student.id %>" style="display: inline;">
            <button type="submit" class="remove-btn" onclick="return confirm('Remove <%= student.name %> from this section?')">Remove</button>
          </form>
        </div>
      <% }) %>
    <% } %>
  </div>

  <h3>📝 Assign Test to Section</h3>
  <div class="test-list">
    <form method="POST" action="/teacher/section/<%= section.id %>/assign-test">
      <select name="testId" required style="width: 70%; padding: 8px; margin-right: 10px;">
        <option value="">Select a test</option>
        <% tests.forEach(test => { %>
          <option value="<%= test.id %>"><%= test.title %> (<%= test.questions.length %> questions)</option>
        <% }) %>
      </select>
      <button type="submit" class="btn">Assign to All Students</button>
    </form>
  </div>
</div>
</body>
</html>